    def _show_api_settings(self):
        status = f"✓ Connected ({self.model_name})" if self.chat_session else "✗ Not Configured"
        key_display = self.api_key[:15] + "..." if self.api_key else "Not Set"
        messagebox.showinfo("API Settings", f"Gemini API Status: {status}\nAPI Key: {key_display}")

    def on_send(self):
        text = self.entry.get("1.0", 'end').strip()
        if not text:
            return "break"
        
        if not self.chat_session:
            messagebox.showerror("Error", "Gemini API key not configured.\n\nSet GEMINI_API_KEY environment variable.")
            return "break"
        
        self.entry.delete("1.0", 'end')
        self._append_chat('user', text)
        self.conversation.append(('user', text))
        self._set_status("🧠 Thinking deeply...")
        self.update()
        
        threading.Thread(target=self._get_response, args=(text,), daemon=True).start()
        return "break"

    def voice_input(self):
        threading.Thread(target=self._voice_input_thread, daemon=True).start()

    def _voice_input_thread(self):
        r = sr.Recognizer()
        try:
            self.q.put(('status', "🎤 Listening... (5 seconds)", False))
            with sr.Microphone() as source:
                audio = r.listen(source, timeout=5, phrase_time_limit=8)
            self.q.put(('status', "🔄 Synthesizing speech...", False))
            text = r.recognize_google(audio)
            self.entry.insert('end', text)
            self.after(100, self.on_send)
        except sr.UnknownValueError:
            self.q.put(('status', "Could not understand audio", True))
            self.after(2000, self._update_status)
        except sr.RequestError as e:
            self.q.put(('status', "Speech recognition unavailable", True))
            self.after(2000, self._update_status)
        except Exception as e:
            self.q.put(('status', f"Error: {str(e)[:40]}", True))
            self.after(2000, self._update_status)

    def _get_response(self, user_input):
        try:
            response = self.chat_session.send_message(user_input)
            assistant_text = response.text
            self.conversation.append(('assistant', assistant_text))
            self.q.put(('assistant', assistant_text))

            try:
                tts_text = assistant_text[:200]
                self.engine.say(tts_text)
                self.engine.runAndWait()
            except:
                pass

        except Exception as e:
            error_msg = f"❌ Error: {str(e)}"
            self.conversation.append(('assistant', error_msg))
            self.q.put(('assistant', error_msg))
        finally:
            self.q.put(('status', "Ready", False))

    def _process_queue(self):
        try:
            while True:
                item = self.q.get_nowait()
                if item[0] == 'assistant':
                    self._append_chat('assistant', item[1])
                    self._update_status()
                elif item[0] == 'status':
                    is_error = len(item) > 2 and item[2]
                    self._set_status(item[1], is_error)
        except queue.Empty:
            pass
        self.after(100, self._process_queue)

